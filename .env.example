# Root-level environment example.
# Copy values into backend/.env or export them in your shell before running the backend.

OPENAI_API_KEY=sk-placeholder
OPENAI_ANALYSIS_MODEL=gpt-4.1
OPENAI_QUESTION_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
DATABASE_URL=sqlite:///./headacheinsight.db
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=120
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://10.0.2.2:8000,http://localhost:8000
ANDROID_BACKEND_BASE_URL=http://10.0.2.2:8000/
ANDROID_DEMO_BACKEND_BASE_URL=http://10.0.2.2:8000/
